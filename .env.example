# Loonymoon Email Gate — shared credentials
#
# Drop this file (renamed to ".env") in one of:
#   • wp-content/.env
#   • one directory above the WordPress root (web-inaccessible — best)
# …on each artist site, OR define the same keys as constants in wp-config.php.
#
# Only LMEG_-prefixed keys are read. Values here WIN over anything entered in
# the admin, and lock those fields in Settings. Per-artist values (Spotify
# artist ID, Shopify store domain, from-addresses) stay in each site's admin.
#
# These are shared across every artist site, so you set them once and copy
# the file to each new site instead of re-typing in wp-admin.

# --- Spotify (analytics) ---
LMEG_SPOTIFY_CLIENT_ID=
LMEG_SPOTIFY_CLIENT_SECRET=

# --- AI assistant (Anthropic) ---
LMEG_AI_API_KEY=
LMEG_AI_MODEL=claude-haiku-4-5-20251001

# --- Email (Brevo) ---
LMEG_BREVO_API_KEY=

# --- SMS (Twilio) ---
LMEG_TWILIO_ACCOUNT_SID=
LMEG_TWILIO_AUTH_TOKEN=
LMEG_TWILIO_FROM_NUMBER=

# --- Payments (Stripe) ---
LMEG_STRIPE_TEST_PK=
LMEG_STRIPE_TEST_SK=
LMEG_STRIPE_TEST_WEBHOOK_SEC=
LMEG_STRIPE_LIVE_PK=
LMEG_STRIPE_LIVE_SK=
LMEG_STRIPE_LIVE_WEBHOOK_SEC=

# --- Instagram (Meta) ---
LMEG_IG_APP_SECRET=
LMEG_IG_PAGE_TOKEN=

# --- Shopify ---
LMEG_SHOPIFY_ADMIN_TOKEN=
